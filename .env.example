# LLM provider switch: openai or gemini
LLM_PROVIDER=openai

# OpenAI API key (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Optional OpenAI default model override
OPENAI_MODEL=gpt-4o

# Gemini API key (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional alias for Gemini API key
GOOGLE_API_KEY=

# Optional Gemini default model override
GEMINI_MODEL=gemini-1.5-pro

# Optional per-flow model overrides
CHAT_LLM_MODEL=
PAPER_EXTRACTION_MODEL=

# Optional explicit Chroma persistence directory (must be writable inside container)
# Example for Docker: CHROMA_DB_PATH=/tmp/chroma_db
CHROMA_DB_PATH=

# NCBI API Key for PubMed citations (optional but recommended for better rate limits)
NCBI_API_KEY=your_ncbi_api_key_here

# Max chars sent to LLM for section-aware paper entity extraction
PAPER_ENTITY_EXTRACTION_MAX_CHARS=9000

# Entity extraction backend: hybrid (default), scispacy, llm
PAPER_ENTITY_EXTRACTION_BACKEND=hybrid

# SciSpaCy settings used when backend is hybrid or scispacy
PAPER_SCISPACY_MODEL=en_ner_bionlp13cg_md
PAPER_SCISPACY_CHUNK_SIZE=50000

# Paper save conflict mode:
# - UPSERT: merge new extraction into existing paper records for the same ID/PMCID
# - OVERWRITE: replace existing paper records for the same ID/PMCID
# Note: OVERWITE (legacy typo) is also accepted.
PAPER_SAVE_MODE=UPSERT

# Instructions:
# 1. Copy this file to .env
# 2. Set LLM_PROVIDER to openai or gemini
# 3. Add the matching API key(s) for the selected provider
# 4. Get OpenAI API key from: https://platform.openai.com/api-keys
# 5. Get Gemini API key from: https://aistudio.google.com/app/apikey
# 6. Get NCBI API key from: https://ncbiinsights.ncbi.nlm.nih.gov/2017/11/02/new-api-keys-for-the-e-utilities/
