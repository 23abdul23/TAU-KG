# OpenAI API Key for GPT-4 enhanced responses
OPENAI_API_KEY=your_openai_api_key_here

# NCBI API Key for PubMed citations (optional but recommended for better rate limits)
NCBI_API_KEY=your_ncbi_api_key_here

# Max chars sent to OpenAI for section-aware paper entity extraction
PAPER_ENTITY_EXTRACTION_MAX_CHARS=9000

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual API keys
# 3. Get OpenAI API key from: https://platform.openai.com/api-keys
# 4. Get NCBI API key from: https://ncbiinsights.ncbi.nlm.nih.gov/2017/11/02/new-api-keys-for-the-e-utilities/
