# Optional settings for bern2_ner.py.
# None of these are required for scispacy_ner.py or biobert_ner.py.

# Local BERN2 endpoint. If set, the script tries this first.
BERN2_LOCAL_URL=http://127.0.0.1:8888/plain

# Fallback public API endpoint.
BERN2_REMOTE_URL=http://bern2.korea.ac.kr/plain

# Shared HTTP settings.
HTTP_USER_AGENT=TAU-KG-NER-Benchmark/1.0
PMC_REQUEST_TIMEOUT=60
BERN2_REQUEST_TIMEOUT=180
